{
  "presets": {
    "code-research": ["chunkhound"],

    "linear": ["linear"],

    "cli-dev": ["shellwright"],
    "web-dev": ["shadcn", "vibium"],
    "ios-dev": ["sosumi", "mobile-mcp", "simctl", "swiftlens", "xcstrings-crud"],

    "ui-automation": ["peekaboo"],

    "docs": ["ref", "tavily", "deepwiki"],
    "research": ["exa", "tavily", "firecrawl"]
  },
  "mcps": {
    "ref": {
      "type": "local",
      "command": ["npx", "ref-tools-mcp@latest"],
      "environment": {
        "REF_API_KEY": "<REF_API_KEY_REDACTED>"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "swiftlens": {
      "type": "local",
      "command": ["uvx", "swiftlens"]
    },
    "chunkhound": {
      "type": "local",
      "command": ["chunkhound", "mcp"]
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"]
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=<TAVILY_API_KEY_REDACTED>"
    },
    "sosumi": {
      "type": "remote",
      "url": "https://sosumi.ai/mcp"
    },
    "mobile-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@mobilenext/mobile-mcp@latest"]
    },
    "simctl": {
      "type": "local",
      "command": ["npx", "-y", "simctl-mcp"]
    },
    "xcodebuild": {
      "type": "local",
      "command": ["npx", "-y", "xcodebuildmcp@latest"]
    },
    "xcstrings-crud": {
      "type": "local",
      "command": ["xcstrings-crud", "mcp"]
    },
    "peekaboo": {
      "type": "local",
      "command": ["peekaboo", "mcp"],
      "environment": {
        "PEEKABOO_AI_PROVIDERS": "openai/gpt-4.1",
        "OPENAI_API_KEY": "<OPENAI_API_KEY_REDACTED>"
      }
    },
    "vibium": {
      "type": "local",
      "command": ["npx", "-y", "vibium", "mcp"]
    },
    "shellwright": {
      "type": "local",
      "command": ["npx", "-y", "@dwmkerr/shellwright"]
    },
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "environment": {
        "FIRECRAWL_API_KEY": "<FIRECRAWL_API_KEY_REDACTED>"
      }
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=<EXA_API_KEY_REDACTED>"
    }
  }
}
