{
  "plugin": [
    "opencode-openai-codex-auth@latest",
    "@plannotator/opencode@latest",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "disabled_providers": ["anthropic", "openrouter", "perplexity"],
  "formatter": {
    "swiftformat": {
      "command": ["swiftformat", "$FILE"],
      "extensions": [".swift"]
    }
  },
  "mcp": {
    "ref": {
      "command": ["npx", "ref-tools-mcp@latest"],
      "type": "local",
      "environment": {
        "REF_API_KEY": "<REF_API_KEY_REDACTED>"
      },
      "enabled": true
    },
    "tavily": {
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=<TAVILY_API_KEY_REDACTED>",
      "type": "remote",
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    },
    "sosumi": {
      "url": "https://sosumi.ai/mcp",
      "type": "remote",
      "enabled": true
    },
    "mobile-mcp": {
      "command": ["npx", "-y", "@mobilenext/mobile-mcp@latest"],
      "type": "local",
      "enabled": true
    },
    "simctl": {
      "command": ["npx", "-y", "simctl-mcp"],
      "type": "local",
      "enabled": true
    },
    "xcodebuild": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "xcodebuildmcp@latest"],
      "environment": {
        "XCODEBUILDMCP_ENABLED_WORKFLOWS": "simulator,logging,project-discovery,utilities,session-management,debugging,simulator-management",
        "INCREMENTAL_BUILDS_ENABLED": "true"
      }
    },
    "xcstrings-crud": {
      "command": ["xcstrings-crud", "mcp"],
      "type": "local",
      "enabled": true
    },
    "vibium": {
      "command": ["npx", "-y", "vibium", "mcp"],
      "type": "local",
      "enabled": false
    },
    "shellwright": {
      "command": ["npx", "-y", "@dwmkerr/shellwright"],
      "type": "local",
      "enabled": false
    },
    "firecrawl": {
      "command": ["npx", "-y", "firecrawl-mcp"],
      "type": "local",
      "environment": {
        "FIRECRAWL_API_KEY": "<FIRECRAWL_API_KEY_REDACTED>"
      },
      "enabled": true
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "type": "remote",
      "enabled": true
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp?exaApiKey=<EXA_API_KEY_REDACTED>",
      "type": "remote",
      "enabled": true
    },
    "linear": {
      "url": "https://mcp.linear.app/mcp",
      "type": "remote",
      "enabled": true
    },
    "swiftlens": {
      "command": ["uvx", "swiftlens"],
      "type": "local",
      "enabled": true
    },
    "xcode-instruments": {
      "command": ["npx", "-y", "instrumentsmcp@latest"],
      "type": "local",
      "enabled": true
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "type": "local",
      "enabled": false
    },
    "morph": {
      "command": ["npx", "-y", "@morphllm/morphmcp"],
      "type": "local",
      "environment": {
        "MORPH_API_KEY": "<MORPH_API_KEY_REDACTED>"
      },
      "enabled": true
    },
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop",
        "--agent",
        "openCodeCLI"
      ],
      "enabled": true,
      "type": "local"
    },
    "xcode-mcpbridge": {
      "command": ["xcrun", "mcpbridge"],
      "type": "local",
      "enabled": true
    }
  },
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["node_modules/@morphllm/opencode-morph-plugin/instructions/morph-tools.md"]
}
