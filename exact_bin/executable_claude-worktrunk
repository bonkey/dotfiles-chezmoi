#!/usr/bin/env zsh
set -uo pipefail

# claude-worktrunk
# Create a worktree off a base branch and launch Claude in it.
# Branch name: <whoami>/<TICKET-ID>-<llm-slug>  (or <whoami>/<llm-slug> with no ticket)
#
# Usage: claude-worktrunk [--resume] [base] [ticket-url-or-key]
#   --resume  reuse this ticket's existing worktree instead of creating a new one
#   .         branch off the current branch
#   <name>    branch off <name>
#   (empty)   branch off the repo's default branch
#   <url|KEY> a Jira/Linear ticket URL or key (e.g. ABC-123) to slug from
#
# A Jira/Linear ticket URL or key passed as an argument supplies the branch
# slug: its title is shortened via the `llm` CLI. With no ticket argument you're
# asked for a purpose and the slug is generated from that. The clipboard is
# never scanned on its own.

source "${HOME}/bin/_common.zsh"

model="gemini-flash-latest"

# Default branch: ask gh first, then origin/HEAD, then a local main/master/trunk.
default_branch() {
    local b c
    b="$(gh repo view --json defaultBranchRef -q .defaultBranchRef.name 2>/dev/null)"
    if [[ -z "$b" ]]; then
        b="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)"
        b="${b#origin/}"
    fi
    if [[ -z "$b" ]]; then
        for c in main master trunk; do
            if git show-ref --verify --quiet "refs/heads/$c"; then b="$c"; break; fi
        done
    fi
    print -r -- "$b"
}

# --- parse args ------------------------------------------------------------
# A ticket is detected only from a URL the user passes explicitly — never from
# the clipboard on its own. Any argument that looks like a ticket URL/key is
# treated as the ticket source; the remaining positional is the base branch.
resume=0
positional=()
ticket_input=""
for a in "$@"; do
    case "$a" in
        --resume)               resume=1 ;;
        *://*|*linear.app*)     ticket_input="$a" ;;
        [A-Z][A-Z]*-[0-9]*)     ticket_input="$a" ;;
        *)                      positional+=("$a") ;;
    esac
done

# --- resolve base branch ---------------------------------------------------
arg="${positional[1]-}"
case "$arg" in
    .)  base="$(git rev-parse --abbrev-ref HEAD 2>/dev/null | head -1)" ;;
    "") base="$(default_branch)" ;;
    *)  base="$arg" ;;
esac
if [[ -z "$base" ]]; then
    print -ru2 -- "could not resolve base branch"
    exit 1
fi

# --- find a ticket in the URL the user passed ------------------------------
# Detection runs only against an explicitly-supplied ticket URL/key, so an
# unrelated clipboard never silently steers the branch name.
clip="$ticket_input"
ticket_id=""
ticket_ctx=""
ticket_title=""

# A passed URL holding several tickets is not a request to branch off any one of
# them, so detection is skipped unless exactly one is found.
if grep -qE 'linear\.app/.+/issue/' <<<"$clip"; then
    # Linear: ID and title come straight from the URL, no API needed.
    ids=("${(@f)$(grep -oE 'issue/[A-Za-z0-9]+-[0-9]+' <<<"$clip" | sort -u)}")
    if (( ${#ids} > 1 )); then
        print -ru2 -- "▲ ${#ids} tickets in the URL — ignoring (pass a single ticket to use it)"
    else
        seg="$(grep -oE 'issue/[A-Za-z0-9]+-[0-9]+(/[A-Za-z0-9-]+)?' <<<"$clip" | head -1)"
        seg="${seg#issue/}"
        id="${seg%%/*}"
        ticket_id="${(U)id}"
        title="${seg#*/}"
        [[ "$title" == "$seg" ]] && title=""
        ticket_title="${title//-/ }"
        ticket_ctx="Linear ${ticket_id}: ${ticket_title}"
    fi
else
    raw_ids="$(grep -oE '[A-Z]{2,}-[0-9]+' <<<"$clip" | sort -u)"
    if [[ -n "$raw_ids" ]]; then
        ids=("${(@f)raw_ids}")
        if (( ${#ids} > 1 )); then
            print -ru2 -- "▲ ${#ids} tickets in the URL — ignoring (pass a single ticket to use it)"
        else
            ticket_id="${ids[1]}"
            summary=""
            if [[ -n "${JIRA_SERVER:-}" && -n "${JIRA_USER:-}" && -n "${JIRA_API_TOKEN:-}" ]]; then
                summary="$(http --verify=no GET "${JIRA_SERVER}/rest/api/3/issue/${ticket_id}" \
                    --auth "${JIRA_USER}:${JIRA_API_TOKEN}" 2>/dev/null \
                    | jq -r '.fields.summary // empty' 2>/dev/null || true)"
            fi
            # Only call it Jira when a Jira summary actually came back; a bare ID
            # (e.g. a Linear key) stays generic with no title to slug from.
            if [[ -n "$summary" ]]; then
                ticket_title="$summary"
                ticket_ctx="Jira ${ticket_id}: ${summary}"
            else
                ticket_ctx="ticket ${ticket_id}"
            fi
        fi
    fi
fi

[[ -n "$ticket_ctx" ]] && print -r -- "ticket: ${ticket_ctx}"

# --- helpers ---------------------------------------------------------------
system_prompt='Generate a git branch slug for the described work. Output ONLY the slug inside a single fenced code block. Rules: lowercase, 2-5 words, hyphen-separated, ASCII letters/digits/hyphens only, no spaces, no ticket IDs, no quotes, max ~40 chars.'

sanitize() {
    local s="${(L)1}"
    s="${s//[^a-z0-9-]/-}"
    while [[ "$s" == *--* ]]; do s="${s//--/-}"; done
    s="${s##-}"; s="${s%%-}"
    s="${s[1,40]}"
    print -r -- "${s%%-}"
}

# make_slug <description> -> slug from the llm, falling back to the raw text.
# A second arg of "continue" keeps the prior conversation (llm -c), so refined
# descriptions build on the former prompt and avoid repeating taken names.
make_slug() {
    local raw s
    if [[ "${2-}" == continue ]]; then
        raw="$(llm -x -c -- "That branch name is taken. More context: $1. Propose a different slug." 2>/dev/null || true)"
    else
        local input="Purpose: $1"
        [[ -n "$ticket_ctx" ]] && input+=$'\n'"Context: ${ticket_ctx}"
        raw="$(llm -x -m "$model" -s "$system_prompt" -- "$input" 2>/dev/null || true)"
    fi
    s="$(sanitize "$raw")"
    [[ -z "$s" ]] && s="$(sanitize "$1")"
    print -r -- "$s"
}

user="$(whoami)"
compose_branch() {  # <slug> -> branch name
    if [[ -n "$ticket_id" ]]; then
        print -r -- "${user}/${ticket_id}-$1"
    else
        print -r -- "${user}/$1"
    fi
}

branch_exists() { git show-ref --verify --quiet "refs/heads/$1"; }

# --- resolve the branch ----------------------------------------------------
# Default is to create a new worktree. With --resume, reuse this ticket's
# existing worktree instead of forking a numbered sibling.
existing=""
if (( resume )) && [[ -n "$ticket_id" ]]; then
    existing="$(git for-each-ref --format='%(refname:short)' refs/heads \
        | grep -m1 "^${user}/${ticket_id}-" || true)"
fi

if [[ -n "$existing" ]]; then
    branch="$existing"
    create_args=()
    print -r -- "resuming existing branch ${branch}"
else
    # With a ticket title from the passed URL, shorten it into a slug
    # automatically; otherwise ask for a purpose to describe the work.
    if [[ -n "$ticket_title" ]]; then
        slug="$(make_slug "$ticket_title")"
    else
        read -r "purpose?Purpose of this worktree: "
        slug="$(make_slug "$purpose")"
    fi
    if [[ -z "$slug" ]]; then
        print -ru2 -- "could not generate a branch slug (empty purpose and llm output)"
        exit 1
    fi
    branch="$(compose_branch "$slug")"

    if [[ -n "$ticket_id" ]]; then
        # The slug is derived from the ticket title, so refining it is pointless;
        # if the branch is taken (re-running on the same ticket) just number it.
        if branch_exists "$branch"; then
            n=2
            while branch_exists "${branch}-${n}"; do (( n++ )); done
            branch="${branch}-${n}"
        fi
    else
        # A purpose-derived name clashing with an unrelated branch: ask for a more
        # specific description; Enter falls back to a numeric suffix.
        while branch_exists "$branch"; do
            print -ru2 -- "▲ branch ${branch} already exists"
            read -r "refine?  refine the purpose (Enter to auto-number): "
            if [[ -z "$refine" ]]; then
                n=2
                while branch_exists "${branch}-${n}"; do (( n++ )); done
                branch="${branch}-${n}"
                break
            fi
            slug="$(make_slug "$refine" continue)"
            [[ -n "$slug" ]] && branch="$(compose_branch "$slug")"
        done
    fi
    create_args=(--create --base "$base")
fi

_exec wt switch "$branch" "${create_args[@]}" \
    --execute claude -- --dangerously-skip-permissions
