#!/usr/bin/env zsh

set +o pipefail

source "{{- .chezmoi.sourceDir}}/exact_bin/_common.zsh"

file="{{- .chezmoi.sourceDir}}/{{- .chezmoi.sourceFile}}"

skills=(
    wisdom-in-a-nutshell/agents
    bonkey/skills
)

for skill in "${skills[@]}"; do
    exec_unless_recently_modified $file "npx -y skills add $skill --global --yes"
done

exec_unless_recently_modified $file "npx -y skills update --global"
